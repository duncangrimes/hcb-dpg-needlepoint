generator client {
  provider      = "prisma-client-js"
  binaryTargets = ["native", "rhel-openssl-3.0.x"]
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

// =============================================================================
// AUTH (NextAuth.js)
// =============================================================================

model Account {
  id                String  @id @default(cuid())
  userId            String  @map("user_id")
  type              String
  provider          String
  providerAccountId String  @map("provider_account_id")
  refresh_token     String? @db.Text
  access_token      String? @db.Text
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String? @db.Text
  session_state     String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
  @@map("accounts")
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique @map("session_token")
  userId       String   @map("user_id")
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("sessions")
}

model User {
  id            String    @id @default(cuid())
  name          String?
  email         String?   @unique
  emailVerified DateTime? @map("email_verified")
  image         String?
  
  accounts     Account[]
  sessions     Session[]
  sourceImages SourceImage[]
  cutouts      Cutout[]
  canvases     Canvas[]
  
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("users")
}

model VerificationToken {
  identifier String
  token      String
  expires    DateTime

  @@unique([identifier, token])
  @@map("verification_tokens")
}

// =============================================================================
// APP MODELS
// =============================================================================

/// Source photo uploaded by user
model SourceImage {
  id     String @id @default(cuid())
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)
  userId String

  url    String // Vercel Blob URL
  width  Int
  height Int

  cutouts Cutout[]

  createdAt DateTime @default(now())

  @@map("source_images")
}

/// A lasso'd region from a source photo (reusable across canvases)
model Cutout {
  id     String @id @default(cuid())
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)
  userId String

  sourceImage   SourceImage @relation(fields: [sourceImageId], references: [id], onDelete: Cascade)
  sourceImageId String

  /// Lasso path as array of {x, y} points (normalized 0-1)
  path Json

  /// Optional user-provided label
  name String?

  /// Extracted cutout image URL (with transparency)
  extractedUrl String?
  
  /// Thumbnail URL for library display (small preview)
  thumbnailUrl String?
  
  /// Bounding box aspect ratio (height/width)
  aspectRatio Float @default(1)

  placements PlacedCutout[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([userId, createdAt(sort: Desc)])
  @@map("cutouts")
}

/// A cutout placed on a canvas with position/transform
model PlacedCutout {
  id String @id @default(cuid())

  canvas   Canvas @relation(fields: [canvasId], references: [id], onDelete: Cascade)
  canvasId String

  cutout   Cutout @relation(fields: [cutoutId], references: [id], onDelete: Cascade)
  cutoutId String

  /// Transform: {x, y, scale, rotation, flipX, flipY}
  transform Json

  /// Layer order (higher = on top)
  zIndex Int @default(0)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([canvasId, cutoutId])
  @@map("placed_cutouts")
}

enum CanvasStatus {
  DRAFT
  PROCESSING
  COMPLETE
  FAILED
}

enum BackgroundPattern {
  SOLID
  GINGHAM
  STRIPES
  CHECKERBOARD
}

/// The final needlepoint canvas
model Canvas {
  id     String @id @default(cuid())
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)
  userId String

  name String?

  // Canvas configuration
  widthInches  Float             @default(8)
  heightInches Float             @default(10)
  meshCount    Int               @default(13)
  bgPattern    BackgroundPattern @default(SOLID)
  bgColor1     String            @default("#FFFFFF")
  bgColor2     String?

  // Placed cutouts
  cutouts PlacedCutout[]

  // Processing status
  status CanvasStatus @default(DRAFT)

  // Generated output (populated after processing)
  manufacturerUrl String?
  threads         Json?    // [{floss, name, hex, r, g, b, stitches, percentage}]
  stitchability   Float?
  widthStitches   Int?
  heightStitches  Int?
  errorMessage    String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("canvases")
}
