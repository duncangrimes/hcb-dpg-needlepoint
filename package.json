{
  "name": "needlejoint",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev",
    "dev:ngrok": "concurrently \"node scripts/start-ngrok.js\" \"npm run dev\" --names \"ngrok,next\" --prefix-colors \"cyan,green\"",
    "build": "prisma generate && next build",
    "start": "next start",
    "lint": "eslint",
    "postinstall": "prisma generate",
    "prisma": "node scripts/prisma-with-env.js",
    "db:migrate": "node scripts/prisma-with-env.js migrate dev",
    "db:push": "node scripts/prisma-with-env.js db push",
    "db:pull": "node scripts/prisma-with-env.js db pull",
    "db:studio": "node scripts/prisma-with-env.js studio",
    "db:seed": "node scripts/prisma-with-env.js db seed",
    "db:reset": "node scripts/prisma-with-env.js migrate reset"
  },
  "dependencies": {
    "@auth/prisma-adapter": "^2.10.0",
    "@google/genai": "^1.28.0",
    "@headlessui/react": "^2.2.8",
    "@heroicons/react": "^2.2.0",
    "@prisma/client": "^6.16.2",
    "@types/culori": "^4.0.1",
    "@types/skmeans": "^0.11.8",
    "@vercel/blob": "^2.0.0",
    "culori": "^4.0.2",
    "image-q": "^4.0.0",
    "next": "15.5.9",
    "next-auth": "^5.0.0-beta.29",
    "nodemailer": "^6.10.1",
    "react": "19.1.0",
    "react-dom": "19.1.0",
    "react-hot-toast": "^2.6.0",
    "recoil": "^0.7.7",
    "resend": "^6.1.0",
    "sharp": "^0.34.4",
    "skmeans": "^0.11.3",
    "vercel": "^48.1.0",
    "zod": "^4.1.11"
  },
  "devDependencies": {
    "@eslint/eslintrc": "^3",
    "@tailwindcss/postcss": "^4",
    "@types/node": "^20",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "concurrently": "^9.2.1",
    "eslint": "^9",
    "eslint-config-next": "15.5.3",
    "prisma": "^6.16.2",
    "tailwindcss": "^4",
    "typescript": "^5"
  }
}
